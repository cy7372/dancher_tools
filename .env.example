# ── GitHub ──────────────────────────────────
# pull.sh 用的 token（cysr 上级的 pull.sh）
GITHUB_TOKEN=

# ── Data ───────────────────────────────────
# 数据集根目录
DATA_ROOT=./datasets

# ── Output ─────────────────────────────────
# 模型保存目录
MODEL_DIR=./checkpoints

# ── Training ───────────────────────────────
# 以下为常用训练参数，可在脚本中通过 os.environ / dotenv 读取
# BATCH_SIZE=16
# NUM_WORKERS=4
# NUM_EPOCHS=500
# LEARNING_RATE=0.001
# PATIENCE=15
# GRAD_CLIP=1.0
